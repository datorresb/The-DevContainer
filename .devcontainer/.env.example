# WARNING: These will be written in plaintext to ~/.git-credentials inside the dev container.
# Only use a PAT with the minimal required scopes.
#
# mv .devcontainer/.env.example .devcontainer/.env
# Then rebuild / reopen the dev container.
#
# Example minimal scopes for typical repo work: repo, workflow (if you trigger actions), read:packages.
# Do NOT store production secrets here.

# Azure DevOps Credentials (if using Azure Repos)
AZURE_DEVOPS_USER=
AZURE_DEVOPS_PAT=
GIT_USER_NAME=
GIT_USER_EMAIL=xx.xx@email.com
INSTALL_AZURE_CLI=false